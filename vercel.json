{
  "version": 2,
  "buildCommand": "pnpm -w run vercel-build",
  "outputDirectory": "artifacts/onelife-finance/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "functions": {
    "api/app.js": {
      "runtime": "@vercel/node@5"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/app.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}

