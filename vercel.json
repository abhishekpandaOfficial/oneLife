{
  "version": 2,
  "buildCommand": "pnpm -w run vercel-build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install",
  "framework": null,
  "functions": {
    "api/app.js": {
      "runtime": "@vercel/node@5"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/app.js" },
    { "source": "/:path*",     "destination": "/index.html" }
  ]
}
